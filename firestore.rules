rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to everyone for the 'cache' collection 
    match /cache/{document=**} {
      allow read, write: if true;
    }
    
    // Allow read access to everyone for the 'users' collection to enable login
    // Allow write access to everyone to change passwords
    match /users/{document=**} {
      allow read, write: if true;
    }
  }
}
